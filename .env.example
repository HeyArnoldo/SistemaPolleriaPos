# ════════════════════════════════════════════════════════════════════
# sistema-polleria-pos — variables de entorno
# Copia este archivo a `.env` en la raíz del repo: cp .env.example .env
# Un solo .env compartido por docker-compose, la API y el frontend.
# ════════════════════════════════════════════════════════════════════

# ── Entorno ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── Base de datos (PostgreSQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=app
DB_PASSWORD=app
DB_NAME=sistema_polleria_pos

# ── API ──────────────────────────────────────────────────────────────
API_PORT=3000
# Orígenes permitidos para CORS, separados por coma (nunca usar *)
CORS_ORIGIN=http://localhost:5173
# URL del frontend (redirects post-login de Google)
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────
# Login con email + password. Ponlo en false para proyectos solo-Google.
AUTH_LOCAL_ENABLED=true
# Mínimo 16 caracteres. Genera uno: openssl rand -base64 32
JWT_SECRET=cambiame_por_un_secreto_largo
# Duración de la sesión: 7d, 12h, 30m...
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Cookie de sesión httpOnly
# En producción detrás de HTTPS: COOKIE_SECURE=true
COOKIE_SECURE=false
# lax para front y api en el mismo dominio/subdominios; none (+secure) si son dominios distintos
COOKIE_SAMESITE=lax
# Para compartir cookie entre subdominios (Coolify): .tudominio.com — vacío en dev
COOKIE_DOMAIN=

# ── Google OAuth (opcional) ──────────────────────────────────────────
# Si defines CLIENT_ID y CLIENT_SECRET, el login con Google se activa solo.
# Si los dejas vacíos, el botón de Google no aparece y las rutas devuelven 404.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Admin inicial (seed idempotente) ─────────────────────────────────
# Con EMAIL + PASSWORD: el seed crea un admin local.
# Con solo EMAIL: ese correo recibe rol admin en su primer login con Google.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Admin

# ── Frontend (Vite) ──────────────────────────────────────────────────
# Vacío en dev (usa el proxy /api de Vite). En producción: https://api.tudominio.com
VITE_API_URL=
