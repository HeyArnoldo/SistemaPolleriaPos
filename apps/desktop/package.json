{
  "name": "@app/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Pollería POS — Electron desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"electron .\"",
    "build": "vite build",
    "dist": "pnpm --filter @app/web build && vite build && node scripts/copy-web.mjs && electron-builder",
    "dist:win": "pnpm --filter @app/web build && vite build && node scripts/copy-web.mjs && electron-builder --win"
  },
  "dependencies": {
    "electron": "^36.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "concurrently": "^9.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.3",
    "vite": "^7.3.0"
  },
  "build": {
    "appId": "com.groow.polleriapos",
    "productName": "Pollería POS",
    "files": [
      "dist-electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "HeyArnoldo",
      "repo": "SistemaPolleriaPos"
    }
  }
}
